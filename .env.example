# ── MediSync AI — environment variables ────────────────────────────────
# Copy to .env.local for local dev, and set the same keys in Vercel
# (Project → Settings → Environment Variables) for production.
# NEVER commit real values — .env* is gitignored.

# ── Owner Supabase project (platform data) ─────────────────────────────
# Project ref: ylvowifrvhkgtvxllghg  (org: plutosystems)
NEXT_PUBLIC_SUPABASE_URL=https://ylvowifrvhkgtvxllghg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Full DB access — must NOT be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── n8n (self-hosted on Hostinger) ─────────────────────────────────────
# Used by /admin/n8n status card and /api/n8n/status (server-only).
N8N_BASE_URL=https://n8n-quc4.srv1825882.hstgr.cloud
N8N_API_KEY=your-n8n-api-key
# Public base for the shared webhooks (Telegram/WhatsApp, Data APIs).
NEXT_PUBLIC_N8N_WEBHOOK_BASE_URL=https://n8n-quc4.srv1825882.hstgr.cloud

# ── Shared secret for the n8n Data Read/Write/Services APIs ─────────────
# MUST be a strong random value set to the SAME string in the n8n
# workflows (Data Read/Write/Services) and here. The source ships a weak
# fallback default for dev only — override it in production.
MEDISYNC_N8N_READ_SECRET=change-me-to-a-strong-random-secret

# ── WhatsApp / Meta Graph API ──────────────────────────────────────────
META_GRAPH_URL=https://graph.facebook.com/v19.0
# Optional: number used by the /api/whatsapp/test diagnostic route.
WHATSAPP_TEST_NUMBER=
